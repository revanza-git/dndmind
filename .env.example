# DNDMind local configuration
#
# Mock mode is the default portfolio/demo path. It does not require a paid LLM key.
MOCK_LLM=true
MOCK_EMBEDDINGS=true

# Real provider mode is future-facing. Keep OPENAI_API_KEY empty for mock mode.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL safe local defaults.
POSTGRES_DB=dndmind
POSTGRES_USER=dndmind
POSTGRES_PASSWORD=dndmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://dndmind:dndmind@postgres:5432/dndmind
POSTGRES_DSN=postgresql://dndmind:dndmind@postgres:5432/dndmind
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=dndmind;Username=dndmind;Password=dndmind

# ASP.NET Core API and service discovery.
ASPNETCORE_ENVIRONMENT=Development
AI_WORKER_URL=http://ai-worker:8001

# Browser-visible API URL. NEXT_PUBLIC_API_BASE_URL is used by the current app;
# NEXT_PUBLIC_API_URL is kept as a readable alias for future cleanup.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
