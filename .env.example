# DNDMind local configuration
#
# Mock mode is the default portfolio/demo path. It does not require a paid LLM key.
MOCK_LLM=true
MOCK_EMBEDDINGS=true

# Real AI mode. Keep provider keys empty for mock mode.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_TIMEOUT_SECONDS=45
IMAGE_GENERATION_ENABLED=false
IMAGE_PROVIDER=mock
IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_ASPECT_RATIO=4:3
IMAGE_TIMEOUT_SECONDS=60
VERTEX_PROJECT_ID=project-de842900-cb0b-4155-b9c
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TEMPERATURE=0.7
VERTEX_TIMEOUT_SECONDS=45
# For Docker Vertex mode, mount ADC credentials into the container and set this path.
GOOGLE_APPLICATION_CREDENTIALS=
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=1536
GEMINI_EMBEDDING_TIMEOUT_SECONDS=45
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_DIMENSIONS=1536
VERTEX_EMBEDDING_TIMEOUT_SECONDS=45
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CHAT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

# PostgreSQL safe local defaults.
POSTGRES_DB=dndmind
POSTGRES_USER=dndmind
POSTGRES_PASSWORD=dndmind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://dndmind:dndmind@postgres:5432/dndmind
POSTGRES_DSN=postgresql://dndmind:dndmind@postgres:5432/dndmind
POSTGRES_CONNECTION_STRING=Host=postgres;Port=5432;Database=dndmind;Username=dndmind;Password=dndmind

# ASP.NET Core API and service discovery.
ASPNETCORE_ENVIRONMENT=Development
AI_WORKER_URL=http://ai-worker:8001
# Comma-separated browser origins allowed to call the API. Leave empty for permissive local Development CORS.
CORS_ALLOWED_ORIGINS=
# Enable only on Cloud Run when ai-worker is private and the API service account has roles/run.invoker.
AI_WORKER_AUTH_ENABLED=false
AI_WORKER_AUTH_AUDIENCE=

# Browser-visible API URL. NEXT_PUBLIC_API_BASE_URL is used by the current app;
# NEXT_PUBLIC_API_URL is kept as a readable alias for future cleanup.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
# Optional Next.js server-side proxy target. For Cloud Run, build web with
# NEXT_PUBLIC_API_BASE_URL=/api/backend and set this to the API service URL.
API_PROXY_BASE_URL=http://localhost:8080
